{{ header }}
{{ column_left }}
<div id="content">
	<div class="page-header">
		<div class="container-fluid">
			<div class="pull-right">
				<button type="submit" form="form-shipping" data-toggle="tooltip" title="{{ button_save }}" class="btn btn-primary"><i class="fa fa-save"></i></button>
				<a href="{{ cancel }}" data-toggle="tooltip" title="{{ button_cancel }}" class="btn btn-default"><i class="fa fa-reply"></i></a>
			</div>
			<h1>{{ heading_title }}</h1>
			<ul class="breadcrumb">
				{% for breadcrumb in breadcrumbs %}
					<li><a href="{{ breadcrumb.href }}">{{ breadcrumb.text }}</a></li>
				{% endfor %}
			</ul>
		</div>
	</div>
	<div class="container-fluid">
		{% if error_warning %}
		<div class="alert alert-danger alert-dismissible">
			<i class="fa fa-exclamation-circle"></i> {{ error_warning }}
			<button type="button" class="close" data-dismiss="alert">&times;</button>
		</div>
		{% endif %}
		<div class="panel panel-default">
			<div class="panel-heading">
				<h3 class="panel-title"><i class="fa fa-pencil"></i> {{ text_edit }}</h3>
			</div>
			<div class="panel-body">
				<form action="{{ action }}" method="post" enctype="multipart/form-data" id="form-shipping" class="form-horizontal">
					<div class="form-group">
						<label class="col-sm-2 control-label" for="input-status">{{ entry_status }}</label>
						<div class="col-sm-10">
							<select name="shipping_xd_flat_status" id="input-status" class="form-control">
								{% if shipping_xd_flat_status %}
									<option value="1" selected="selected">{{ text_enabled }}</option>
									<option value="0">{{ text_disabled }}</option>
								{% else %}
									<option value="1">{{ text_enabled }}</option>
									<option value="0" selected="selected">{{ text_disabled }}</option>
								{% endif %}
							</select>
						</div>
					</div>
					<div class="form-group">
						<label class="col-sm-2 control-label" for="input-sort-order">{{ entry_sort_order }}</label>
						<div class="col-sm-10">
							<input type="text" name="shipping_xd_flat_sort_order" value="{{ shipping_xd_flat_sort_order }}" placeholder="{{ entry_sort_order }}" id="input-sort-order" class="form-control" />
						</div>
					</div>

					<fieldset>
						<legend>{{ text_rate }}</legend>
						<div class="table-responsive">
							<table id="rate" class="table table-striped table-bordered table-hover">
								<thead>
									<tr>
										<td class="text-left">{{ entry_title }}</td>
										<td class="text-left" style="width: 90px;">{{ entry_image }}</td>
										<td class="text-left" style="width: 120px;">{{ entry_cost }}</td>
										<td class="text-left" style="width: 180px;">{{ entry_tax_class }}</td>
										<td class="text-left" style="width: 180px;">{{ entry_geo_zone }}</td>
										<td class="text-left" style="width: 120px;">{{ entry_sort_order }}</td>
										<td class="text-left" style="width: 140px;">{{ entry_status }}</td>
										<td></td>
									</tr>
								</thead>
								<tbody>
									{% set rate_row = 0 %}
									{% for rate in shipping_xd_flat_rate %}
									<tr id="rate-row{{ rate_row }}">
										<td class="text-left"><input type="text" name="shipping_xd_flat_rate[{{ rate_row }}][title]" value="{{ rate.title }}" placeholder="{{ entry_title }}" class="form-control" /></td>
										<td class="text-left">
											<a href="" id="thumb-image-{{ rate_row }}" data-toggle="image" class="img-thumbnail"><img src="{{ rate.thumb }}" alt="" title="" data-placeholder="{{ placeholder }}" /></a>
											<input type="hidden" name="shipping_xd_flat_rate[{{ rate_row }}][image]" value="{{ rate.image|default('') }}" id="input-image-{{ rate_row }}" />
										</td>
										<td class="text-left"><input type="text" name="shipping_xd_flat_rate[{{ rate_row }}][cost]" value="{{ rate.cost }}" placeholder="{{ entry_cost }}" class="form-control" /></td>
										<td class="text-left">
											<select name="shipping_xd_flat_rate[{{ rate_row }}][tax_class_id]" class="form-control">
												<option value="0">{{ text_none }}</option>
												{% for tax_class in tax_classes %}
												{% if tax_class.tax_class_id == rate.tax_class_id %}
												<option value="{{ tax_class.tax_class_id }}" selected="selected">{{ tax_class.title }}</option>
												{% else %}
												<option value="{{ tax_class.tax_class_id }}">{{ tax_class.title }}</option>
												{% endif %}
												{% endfor %}
											</select>
										</td>
										<td class="text-left">
											<select name="shipping_xd_flat_rate[{{ rate_row }}][geo_zone_id]" class="form-control">
												<option value="0">{{ text_all_zones }}</option>
												{% for geo_zone in geo_zones %}
												{% if geo_zone.geo_zone_id == rate.geo_zone_id %}
												<option value="{{ geo_zone.geo_zone_id }}" selected="selected">{{ geo_zone.name }}</option>
												{% else %}
												<option value="{{ geo_zone.geo_zone_id }}">{{ geo_zone.name }}</option>
												{% endif %}
												{% endfor %}
											</select>
										</td>
										<td class="text-left"><input type="text" name="shipping_xd_flat_rate[{{ rate_row }}][sort_order]" value="{{ rate.sort_order }}" placeholder="{{ entry_sort_order }}" class="form-control" /></td>
										<td class="text-left">
											<select name="shipping_xd_flat_rate[{{ rate_row }}][status]" class="form-control">
												{% if rate.status %}
												<option value="1" selected="selected">{{ text_enabled }}</option>
												<option value="0">{{ text_disabled }}</option>
												{% else %}
												<option value="1">{{ text_enabled }}</option>
												<option value="0" selected="selected">{{ text_disabled }}</option>
												{% endif %}
											</select>
										</td>
										<td class="text-right"><button type="button" onclick="$('#rate-row{{ rate_row }}').remove();" data-toggle="tooltip" title="{{ button_remove }}" class="btn btn-danger"><i class="fa fa-minus-circle"></i></button></td>
									</tr>
									{% set rate_row = rate_row + 1 %}
									{% endfor %}
								</tbody>
								<tfoot>
									<tr>
										<td colspan="7"></td>
										<td class="text-right"><button type="button" onclick="addRate();" data-toggle="tooltip" title="{{ button_add_rate }}" class="btn btn-primary"><i class="fa fa-plus-circle"></i></button></td>
									</tr>
								</tfoot>
							</table>
						</div>
					</fieldset>
				</form>
			</div>
		</div>
	</div>
</div>

<script type="text/javascript"><!--
var rate_row = {{ rate_row|default(0) }};

function addRate() {
	html  = '<tr id="rate-row' + rate_row + '">';
	html += '<td class="text-left"><input type="text" name="shipping_xd_flat_rate[' + rate_row + '][title]" value="" placeholder="{{ entry_title }}" class="form-control" /></td>';
	html += '<td class="text-left"><a href="" id="thumb-image-' + rate_row + '" data-toggle="image" class="img-thumbnail"><img src="{{ placeholder }}" alt="" title="" data-placeholder="{{ placeholder }}" /></a><input type="hidden" name="shipping_xd_flat_rate[' + rate_row + '][image]" value="" id="input-image-' + rate_row + '" /></td>';
	html += '<td class="text-left"><input type="text" name="shipping_xd_flat_rate[' + rate_row + '][cost]" value="" placeholder="{{ entry_cost }}" class="form-control" /></td>';
	html += '<td class="text-left"><select name="shipping_xd_flat_rate[' + rate_row + '][tax_class_id]" class="form-control"><option value="0">{{ text_none }}</option>{% for tax_class in tax_classes %}<option value="{{ tax_class.tax_class_id }}">{{ tax_class.title|e('js') }}</option>{% endfor %}</select></td>';
	html += '<td class="text-left"><select name="shipping_xd_flat_rate[' + rate_row + '][geo_zone_id]" class="form-control"><option value="0">{{ text_all_zones }}</option>{% for geo_zone in geo_zones %}<option value="{{ geo_zone.geo_zone_id }}">{{ geo_zone.name|e('js') }}</option>{% endfor %}</select></td>';
	html += '<td class="text-left"><input type="text" name="shipping_xd_flat_rate[' + rate_row + '][sort_order]" value="0" placeholder="{{ entry_sort_order }}" class="form-control" /></td>';
	html += '<td class="text-left"><select name="shipping_xd_flat_rate[' + rate_row + '][status]" class="form-control"><option value="1">{{ text_enabled }}</option><option value="0">{{ text_disabled }}</option></select></td>';
	html += '<td class="text-right"><button type="button" onclick="$(\'#rate-row' + rate_row + '\').remove();" data-toggle="tooltip" title="{{ button_remove }}" class="btn btn-danger"><i class="fa fa-minus-circle"></i></button></td>';
	html += '</tr>';

	$('#rate tbody').append(html);

	rate_row++;
}
//--></script>
{{ footer }}